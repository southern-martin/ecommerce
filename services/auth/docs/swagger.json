                "email": {
                    "type": "string"
                },
                "refresh_token": {
                    "type": "string"
                },
                "role": {
                    "type": "string"
                },
                "user_id": {
                    "type": "string"
                }
            }
        },
        "github_com_southern-martin_ecommerce_services_auth_internal_usecase.LogoutInput": {
            "type": "object",
            "required": [
                "access_token"
            ],
            "properties": {
                "access_token": {
                    "type": "string"
                },
                "user_id": {
                    "type": "string"
                }
            }
        },
        "github_com_southern-martin_ecommerce_services_auth_internal_usecase.OAuthLoginInput": {
            "type": "object",
            "required": [
                "email",
                "provider",
