                    "type": "string"
                },
                "password": {
                    "type": "string"
                }
            }
        },
        "github_com_southern-martin_ecommerce_services_auth_internal_usecase.LoginOutput": {
            "type": "object",
            "properties": {
                "access_token": {
                    "type": "string"
