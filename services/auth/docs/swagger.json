            "properties": {
                "email": {
                    "type": "string"
                },
                "provider": {
                    "type": "string"
                },
                "provider_id": {
                    "type": "string"
                }
            }
        },
        "github_com_southern-martin_ecommerce_services_auth_internal_usecase.OAuthLoginOutput": {
            "type": "object",
            "properties": {
                "access_token": {
                    "type": "string"
