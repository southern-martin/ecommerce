{
    "swagger": "2.0",
    "info": {
        "description": "Tax calculation, zone management, and tax rule configuration.",
        "title": "Tax Service API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:28098",
    "basePath": "/api/v1",
    "paths": {
        "/admin/tax/rules": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Tax"
                ],
                "summary": "List tax rules",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Filter by zone ID",
                        "name": "zone_id",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "rules": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/definitions/internal_adapter_http.ruleResponse"
                                    }
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Tax"
                ],
                "summary": "Create a tax rule",
                "parameters": [
                    {
                        "description": "Tax rule to create",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_adapter_http.createRuleRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "rule": {
                                    "$ref": "#/definitions/internal_adapter_http.ruleResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/admin/tax/rules/{id}": {
            "delete": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Tax"
                ],
                "summary": "Delete a tax rule",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Rule ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            },
            "patch": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Tax"
                ],
                "summary": "Update a tax rule",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Rule ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Fields to update",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_adapter_http.updateRuleRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "rule": {
                                    "$ref": "#/definitions/internal_adapter_http.ruleResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/tax/calculate": {
            "post": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Tax"
                ],
                "summary": "Calculate tax for items",
                "parameters": [
                    {
                        "description": "Items and shipping address",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_adapter_http.calculateTaxRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "breakdown": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/definitions/internal_adapter_http.taxBreakdownResponse"
                                    }
                                },
                                "subtotal_cents": {
                                    "type": "integer",
                                    "format": "int64"
                                },
                                "tax_amount_cents": {
                                    "type": "integer",
                                    "format": "int64"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/tax/zones": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Tax"
                ],
                "summary": "List all tax zones",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "zones": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/definitions/internal_adapter_http.zoneResponse"
                                    }
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "error": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "internal_adapter_http.calculateTaxRequest": {
            "type": "object",
            "required": [
                "items",
                "shipping_address"
            ],
            "properties": {
                "items": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/internal_adapter_http.taxItemRequest"
                    }
                },
                "shipping_address": {
                    "$ref": "#/definitions/internal_adapter_http.taxAddressRequest"
                }
            }
        },
        "internal_adapter_http.createRuleRequest": {
            "type": "object",
            "required": [
                "rate",
                "tax_name",
                "zone_id"
            ],
            "properties": {
                "category": {
                    "type": "string"
                },
                "expires_at": {
                    "type": "string"
                },
                "inclusive": {
                    "type": "boolean"
                },
                "rate": {
                    "type": "number"
                },
                "starts_at": {
                    "type": "string"
                },
                "tax_name": {
                    "type": "string"
                },
                "zone_id": {
                    "type": "string"
                }
            }
        },
        "internal_adapter_http.ruleResponse": {
            "type": "object",
            "properties": {
                "category": {
                    "type": "string"
                },
                "expires_at": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "inclusive": {
                    "type": "boolean"
                },
                "is_active": {
                    "type": "boolean"
                },
                "rate": {
                    "type": "number"
                },
                "starts_at": {
                    "type": "string"
                },
                "tax_name": {
                    "type": "string"
                },
                "zone_id": {
                    "type": "string"
                }
            }
        },
        "internal_adapter_http.taxAddressRequest": {
            "type": "object",
            "required": [
                "country_code"
            ],
            "properties": {
                "city": {
                    "type": "string"
                },
                "country_code": {
                    "type": "string"
                },
                "postal_code": {
                    "type": "string"
                },
                "state_code": {
                    "type": "string"
                }
            }
        },
        "internal_adapter_http.taxBreakdownResponse": {
            "type": "object",
            "properties": {
                "amount_cents": {
                    "type": "integer"
                },
                "jurisdiction": {
                    "type": "string"
                },
                "rate": {
                    "type": "number"
                },
                "tax_name": {
                    "type": "string"
                }
            }
        },
        "internal_adapter_http.taxItemRequest": {
            "type": "object",
            "required": [
                "price_cents",
                "quantity"
            ],
            "properties": {
                "category": {
                    "type": "string"
                },
                "price_cents": {
                    "type": "integer"
                },
                "product_id": {
                    "type": "string"
                },
                "quantity": {
                    "type": "integer"
                },
                "variant_id": {
                    "type": "string"
                }
            }
        },
        "internal_adapter_http.updateRuleRequest": {
            "type": "object",
            "properties": {
                "category": {
                    "type": "string"
                },
                "expires_at": {
                    "type": "string"
                },
                "inclusive": {
                    "type": "boolean"
                },
                "is_active": {
                    "type": "boolean"
                },
                "rate": {
                    "type": "number"
                },
                "tax_name": {
                    "type": "string"
                }
            }
        },
        "internal_adapter_http.zoneResponse": {
            "type": "object",
            "properties": {
                "country_code": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "state_code": {
                    "type": "string"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "description": "JWT Bearer token (via Kong gateway)",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}