# =============================================================================
# Production Environment Variables
# =============================================================================
# Copy this file to .env.production and fill in all values.
# Usage: docker-compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.production up -d
#
# IMPORTANT: Never commit .env.production to version control.
# =============================================================================

# ─────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=              # REQUIRED: Strong password for PostgreSQL

# ─────────────────────────────────────────────
# Cache (Redis)
# ─────────────────────────────────────────────
REDIS_PASSWORD=                 # REQUIRED: Password for Redis AUTH

# ─────────────────────────────────────────────
# Search (Elasticsearch)
# ─────────────────────────────────────────────
ELASTIC_PASSWORD=               # REQUIRED: Password for Elasticsearch

# ─────────────────────────────────────────────
# Authentication / JWT
# ─────────────────────────────────────────────
JWT_SECRET=                     # REQUIRED: 256-bit secret for JWT signing (min 32 chars)

# ─────────────────────────────────────────────
# Payment (Stripe)
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=              # REQUIRED: Stripe live secret key (sk_live_...)
STRIPE_WEBHOOK_SECRET=          # REQUIRED: Stripe webhook signing secret (whsec_...)

# ─────────────────────────────────────────────
# Object Storage (MinIO / S3)
# ─────────────────────────────────────────────
MINIO_ROOT_USER=                # REQUIRED: MinIO or S3-compatible access key
MINIO_ROOT_PASSWORD=            # REQUIRED: MinIO or S3-compatible secret key
S3_PUBLIC_ENDPOINT=             # REQUIRED: Public-facing URL for media (e.g., cdn.example.com)

# ─────────────────────────────────────────────
# Email (SMTP)
# ─────────────────────────────────────────────
SMTP_HOST=                      # REQUIRED: SMTP server hostname (e.g., smtp.sendgrid.net)
SMTP_PORT=587                   # SMTP port (587 for TLS, 465 for SSL)
SMTP_USER=                      # REQUIRED: SMTP username / API key
SMTP_PASSWORD=                  # REQUIRED: SMTP password

# ─────────────────────────────────────────────
# AI Service
# ─────────────────────────────────────────────
AI_PYTHON_SERVICE_URL=http://ai-python:8000   # Override if AI service is external
